# SwifterKit releases are source tags and do not require Apple signing.
# These values validate a release-configured generated dext locally.
DEVELOPMENT_TEAM="ABCDEF1234"
CODESIGN_IDENTITY="Apple Development: Your Name (ABCDEF1234)"
DEXT_BUNDLE_IDENTIFIER="com.example.SwifterKitRuntime"
DEXT_PROVISIONING_PROFILE_SPECIFIER="SwifterKit Runtime Distribution"
SIGNING_KEYCHAIN=""

# A downstream host app uses these when it notarizes its app containing the dext.
NOTARIZE_APPLE_ID=""
NOTARIZE_PASSWORD=""
NOTARIZE_KEYCHAIN_PROFILE=""
